{"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"type":"text","text":"Pass pre-localized strings into "},{"type":"reference","isActive":true,"identifier":"doc:\/\/AppFeedbackUI\/documentation\/AppFeedbackUI\/FeedbackTheme\/Copy-swift.struct"},{"type":"text","text":" so the SDK doesn’t have to ship a strings table."}],"sections":[],"metadata":{"roleHeading":"API Collection","title":"Localization","role":"collectionGroup","modules":[{"name":"AppFeedbackUI"}]},"topicSections":[{"identifiers":["doc:\/\/AppFeedbackUI\/documentation\/AppFeedbackUI\/FeedbackTheme\/Copy-swift.struct","doc:\/\/AppFeedbackUI\/documentation\/AppFeedbackUI\/FeedbackTheme"],"anchor":"Topics"}],"seeAlsoSections":[{"identifiers":["doc:\/\/AppFeedbackUI\/documentation\/AppFeedbackUI\/Theming","doc:\/\/AppFeedbackUI\/documentation\/AppFeedbackUI\/FeedbackTheme"],"generated":true,"anchor":"Customization","title":"Customization"}],"primaryContentSections":[{"content":[{"type":"heading","level":2,"anchor":"Overview","text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/AppFeedbackUI\/documentation\/AppFeedbackUI\/FeedbackTheme\/Copy-swift.struct","isActive":true},{"text":" uses plain ","type":"text"},{"code":"String","type":"codeVoice"},{"text":" fields rather than ","type":"text"},{"code":"LocalizedStringKey","type":"codeVoice"},{"text":". This is deliberate: integrators ship their own strings catalogs and pass already-localized text into the theme. The SDK doesn’t bundle a strings file, doesn’t pick a locale, and doesn’t override your app’s localization workflow.","type":"text"}]},{"type":"heading","level":2,"anchor":"Using-Stringlocalized","text":"Using `String(localized:)`"},{"type":"paragraph","inlineContent":[{"text":"In a localized app (","type":"text"},{"code":".xcstrings","type":"codeVoice"},{"text":" catalog or ","type":"text"},{"code":"Localizable.strings","type":"codeVoice"},{"text":"):","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let copy = FeedbackTheme.Copy(","    headerTitle:             String(localized: \"feedback_header\"),","    bugSubtitle:             String(localized: \"feedback_bug_subtitle\"),","    featureSubtitle:         String(localized: \"feedback_feature_subtitle\"),","    bugLabel:                String(localized: \"feedback_type_bug\"),","    bugTagline:              String(localized: \"feedback_type_bug_tagline\"),","    featureLabel:            String(localized: \"feedback_type_feature\"),","    featureTagline:          String(localized: \"feedback_type_feature_tagline\"),","    titleLabel:              String(localized: \"feedback_title_label\"),","    titleFieldName:          String(localized: \"feedback_title_label\"),","    titlePlaceholder:        String(localized: \"feedback_title_placeholder\"),","    descriptionLabel:        String(localized: \"feedback_description_label\"),","    descriptionFieldName:    String(localized: \"feedback_description_label\"),","    descriptionPlaceholder:  String(localized: \"feedback_description_placeholder\"),","    emailLabel:              String(localized: \"feedback_email_label\"),","    emailOptionalBadge:      String(localized: \"feedback_optional\"),","    emailPlaceholder:        String(localized: \"feedback_email_placeholder\"),","    emailHint:               String(localized: \"feedback_email_hint\"),","    privacyNotice:           String(localized: \"feedback_privacy_notice\"),","    submitButton:            String(localized: \"feedback_submit_button\"),","    doneButton:              String(localized: \"feedback_done_button\"),","    successTitle:            String(localized: \"feedback_success_title\"),","    successMessage:          String(localized: \"feedback_success_message\"),","    errorAlertTitle:         String(localized: \"feedback_error_title\"),","    validationPromptTemplate: String(localized: \"feedback_validation_template\")",")"]},{"type":"paragraph","inlineContent":[{"code":"String(localized:)","type":"codeVoice"},{"text":" resolves at runtime against ","type":"text"},{"code":"Bundle.main","type":"codeVoice"},{"text":", so each call picks up the user’s current locale and any in-flight language change.","type":"text"}]},{"type":"heading","level":2,"anchor":"The-validation-prompt-template","text":"The validation prompt template"},{"type":"paragraph","inlineContent":[{"code":"validationPromptTemplate","type":"codeVoice"},{"text":" is interpolated when the user submits with required fields blank. The literal token ","type":"text"},{"code":"{fields}","type":"codeVoice"},{"text":" is replaced with a comma-separated list of missing field names:","type":"text"}]},{"type":"codeListing","syntax":"text","code":["\"Please fill in: {fields}\"   →   \"Please fill in: Title, Description\""]},{"type":"paragraph","inlineContent":[{"text":"For locales that need different word order, encode it in the template:","type":"text"}]},{"type":"codeListing","syntax":"text","code":["\"Bitte ausfüllen: {fields}\"   →   \"Bitte ausfüllen: Titel, Beschreibung\""]},{"type":"paragraph","inlineContent":[{"text":"The names that fill ","type":"text"},{"code":"{fields}","type":"codeVoice"},{"text":" come from ","type":"text"},{"code":"titleFieldName","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"descriptionFieldName","type":"codeVoice"},{"text":". Keep those short and in the same locale.","type":"text"}]},{"type":"heading","level":2,"anchor":"Right-to-left-layout","text":"Right-to-left layout"},{"type":"paragraph","inlineContent":[{"text":"SwiftUI handles RTL automatically — the entire sheet flips when the system layout direction is right-to-left. No extra theme work needed; just provide RTL-correct copy strings.","type":"text"}]}],"kind":"content"}],"variants":[{"paths":["\/documentation\/appfeedbackui\/localization"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"article","hierarchy":{"paths":[["doc:\/\/AppFeedbackUI\/documentation\/AppFeedbackUI"],["doc:\/\/App