{"topicSections":[{"anchor":"Topics","identifiers":["doc:\/\/AppFeedbackUI\/documentation\/AppFeedbackUI\/FeedbackTheme\/Copy-swift.struct","doc:\/\/AppFeedbackUI\/documentation\/AppFeedbackUI\/FeedbackTheme"]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"role":"collectionGroup","modules":[{"name":"AppFeedbackUI"}],"roleHeading":"API Collection","title":"Localization"},"variants":[{"paths":["\/documentation\/appfeedbackui\/localization"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"type":"text","text":"Pass pre-localized strings into "},{"type":"reference","identifier":"doc:\/\/AppFeedbackUI\/documentation\/AppFeedbackUI\/FeedbackTheme\/Copy-swift.struct","isActive":true},{"type":"text","text":" so the SDK doesn’t have to ship a strings table."}],"primaryContentSections":[{"content":[{"level":2,"type":"heading","text":"Overview","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/AppFeedbackUI\/documentation\/AppFeedbackUI\/FeedbackTheme\/Copy-swift.struct"},{"type":"text","text":" uses plain "},{"type":"codeVoice","code":"String"},{"type":"text","text":" fields rather than "},{"type":"codeVoice","code":"LocalizedStringKey"},{"type":"text","text":". This is deliberate: integrators ship their own strings catalogs and pass already-localized text into the theme. The SDK doesn’t bundle a strings file, doesn’t pick a locale, and doesn’t override your app’s localization workflow."}]},{"level":2,"type":"heading","text":"Using `String(localized:)`","anchor":"Using-Stringlocalized"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In a localized app ("},{"type":"codeVoice","code":".xcstrings"},{"type":"text","text":" catalog or "},{"type":"codeVoice","code":"Localizable.strings"},{"type":"text","text":"):"}]},{"syntax":"swift","type":"codeListing","code":["let copy = FeedbackTheme.Copy(","    headerTitle:             String(localized: \"feedback_header\"),","    bugSubtitle:             String(localized: \"feedback_bug_subtitle\"),","    featureSubtitle:         String(localized: \"feedback_feature_subtitle\"),","    bugLabel:                String(localized: \"feedback_type_bug\"),","    bugTagline:              String(localized: \"feedback_type_bug_tagline\"),","    featureLabel:            String(localized: \"feedback_type_feature\"),","    featureTagline:          String(localized: \"feedback_type_feature_tagline\"),","    titleLabel:              String(localized: \"feedback_title_label\"),","    titleFieldName:          String(localized: \"feedback_title_label\"),","    titlePlaceholder:        String(localized: \"feedback_title_placeholder\"),","    descriptionLabel:        String(localized: \"feedback_description_label\"),","    descriptionFieldName:    String(localized: \"feedback_description_label\"),","    descriptionPlaceholder:  String(localized: \"feedback_description_placeholder\"),","    emailLabel:              String(localized: \"feedback_email_label\"),","    emailOptionalBadge:      String(localized: \"feedback_optional\"),","    emailPlaceholder:        String(localized: \"feedback_email_placeholder\"),","    emailHint:               String(localized: \"feedback_email_hint\"),","    privacyNotice:           String(localized: \"feedback_privacy_notice\"),","    submitButton:            String(localized: \"feedback_submit_button\"),","    doneButton:              String(localized: \"feedback_done_button\"),","    successTitle:            String(localized: \"feedback_success_title\"),","    successMessage:          String(localized: \"feedback_success_message\"),","    errorAlertTitle:         String(localized: \"feedback_error_title\"),","    validationPromptTemplate: String(localized: \"feedback_validation_template\")",")"]},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"String(localized:)"},{"type":"text","text":" resolves at runtime against "},{"type":"codeVoice","code":"Bundle.main"},{"type":"text","text":", so each call picks up the user’s current locale and any in-flight language change."}]},{"level":2,"type":"heading","text":"The validation prompt template","anchor":"The-validation-prompt-template"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"validationPromptTemplate"},{"type":"text","text":" is interpolated when the user submits with required fields blank. The literal token "},{"type":"codeVoice","code":"{fields}"},{"type":"text","text":" is replaced with a comma-separated list of missing field names:"}]},{"syntax":"text","type":"codeListing","code":["\"Please fill in: {fields}\"   →   \"Please fill in: Title, Description\""]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For locales that need different word order, encode it in the template:"}]},{"syntax":"text","type":"codeListing","code":["\"Bitte ausfüllen: {fields}\"   →   \"Bitte ausfüllen: Titel, Beschreibung\""]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The names that fill "},{"type":"codeVoice","code":"{fields}"},{"type":"text","text":" come from "},{"type":"codeVoice","code":"titleFieldName"},{"type":"text","text":" and "},{"type":"codeVoice","code":"descriptionFieldName"},{"type":"text","text":". Keep those short and in the same locale."}]},{"level":2,"type":"heading","text":"Right-to-left layout","anchor":"Right-to-left-layout"},{"type":"paragraph","inlineContent":[{"type":"text","text":"SwiftUI handles RTL automatically — the entire sheet flips when the system layout direction is right-to-left. No extra theme work needed; just provide RTL-correct copy strings."}]}],"kind":"content"}],"sections":[],"seeAlsoSections":[{"generated":true,"title":"Customization","anchor":"Customization","identifiers":["doc:\/\/AppFeedbackUI\/documentation\/AppFeedbackUI\/Theming","doc:\/\/AppFeedbackUI\/documentation\/AppFeedbackUI\/FeedbackTheme"]}],"hierarchy":{"paths":[["doc:\/\/AppFeedbackUI\/documentation\/AppFeedbackUI"],["doc:\/\/AppFeedbackUI\/docum