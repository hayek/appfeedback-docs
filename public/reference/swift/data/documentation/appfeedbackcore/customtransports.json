{"abstract":[{"text":"Replace ","type":"text"},{"isActive":true,"identifier":"doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/GitHubDirectTransport","type":"reference"},{"text":" with a relay server, a mock, or any other backend by conforming to ","type":"text"},{"identifier":"doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/FeedbackTransport","isActive":true,"type":"reference"},{"type":"text","text":"."}],"identifier":{"url":"doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/CustomTransports","interfaceLanguage":"swift"},"seeAlsoSections":[{"title":"Transports","identifiers":["doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/SecretsAndTokens","doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/FeedbackTransport","doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/GitHubDirectTransport","doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/RelayTransport"],"anchor":"Transports","generated":true}],"primaryContentSections":[{"kind":"content","content":[{"level":2,"type":"heading","text":"Overview","anchor":"Overview"},{"inlineContent":[{"identifier":"doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/FeedbackClient","type":"reference","isActive":true},{"text":" knows nothing about GitHub. All it does is collect ","type":"text"},{"identifier":"doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/DeviceInfo","type":"reference","isActive":true},{"text":" and hand the ","type":"text"},{"identifier":"doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/FeedbackReport","type":"reference","isActive":true},{"text":" to its ","type":"text"},{"identifier":"doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/FeedbackTransport","type":"reference","isActive":true},{"text":". Anything that can produce an ","type":"text"},{"type":"codeVoice","code":"Int"},{"text":" from that pair is a valid transport.","type":"text"}],"type":"paragraph"},{"code":["public protocol FeedbackTransport: Sendable {","    func submit(_ report: FeedbackReport, deviceInfo: DeviceInfo) async throws -> Int","}"],"syntax":"swift","type":"codeListing"},{"level":2,"anchor":"Use-the-built-in-relay-transport","type":"heading","text":"Use the built-in relay transport"},{"inlineContent":[{"type":"text","text":"The most common reason to replace the default transport is to avoid shipping a GitHub PAT inside the app binary (see "},{"type":"reference","isActive":true,"identifier":"doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/SecretsAndTokens"},{"text":"). A relay server holds the credential, exposes a thin HTTPS endpoint, and applies abuse controls. ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"You don’t have to write this transport"}]},{"text":" — the SDK ships ","type":"text"},{"identifier":"doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/RelayTransport","type":"reference","isActive":true},{"text":", which speaks the canonical relay contract (the same one the AppFeedback Web and Android SDKs target):","type":"text"}],"type":"paragraph"},{"code":["let transport = RelayTransport(","    endpoint: URL(string: \"https:\/\/your-relay.example.com\/api\/feedback\")!,","    captchaToken: token   \/\/ optional Turnstile\/hCaptcha token, omitted when nil",")","let feedback = FeedbackClient(appName: \"AcmeApp\", transport: transport)"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/RelayTransport"},{"text":" POSTs a JSON body with ","type":"text"},{"type":"codeVoice","code":"type"},{"type":"text","text":", "},{"code":"title","type":"codeVoice"},{"text":", ","type":"text"},{"code":"description","type":"codeVoice"},{"type":"text","text":", optional "},{"type":"codeVoice","code":"contactEmail"},{"text":", ","type":"text"},{"type":"codeVoice","code":"extraFields"},{"type":"text","text":", a nested "},{"code":"deviceInfo","type":"codeVoice"},{"type":"text","text":" object, and optional "},{"type":"codeVoice","code":"captchaToken"},{"text":", then decodes the relay’s ","type":"text"},{"type":"codeVoice","code":"{ \"issueNumber\", \"issueUrl\" }"},{"type":"text","text":" response. No GitHub credential ever ships in the app binary."}],"type":"paragraph"},{"level":2,"anchor":"Writing-your-own-relay-transport","text":"Writing your own relay transport","type":"heading"},{"inlineContent":[{"text":"If your backend speaks a different protocol, conform to ","type":"text"},{"identifier":"doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/FeedbackTransport","isActive":true,"type":"reference"},{"text":" directly. The example below mirrors the same wire shape ","type":"text"},{"identifier":"doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/RelayTransport","isActive":true,"type":"reference"},{"type":"text","text":" uses — a nested "},{"code":"deviceInfo","type":"codeVoice"},{"type":"text","text":" object, "},{"code":"contactEmail","type":"codeVoice"},{"text":" (not ","type":"text"},{"code":"email","type":"codeVoice"},{"type":"text","text":"), and "},{"code":"extraFields","type":"codeVoice"},{"text":" plus an optional ","type":"text"},{"code":"captchaToken","type":"codeVoice"},{"text":":","type":"text"}],"type":"paragraph"},{"code":["public struct MyRelayTransport: FeedbackTransport {","    public let endpoint: URL","    public let captchaToken: String?","    public let session: URLSession","","    public init(endpoint: URL, captchaToken: String? = nil, session: URLSession = .shared) {","        self.endpoint = endpoint","        self.captchaToken = captchaToken","        self.session = session","    }","","    public func submit(_ report: FeedbackReport, deviceInfo: DeviceInfo) async throws -> Int {","        struct DeviceInfoPayload: Encodable {","            let appName: String","            let appVersion: String","            let buildNumber: String","            let model: String","            let osName: String","            let osVersion: String","        }","        struct Payload: Encodable {","            let type: FeedbackType","            let title: String","            let description: String","            let contactEmail: String?","            let extraFields: [String: String]","            let deviceInfo: DeviceInfoPayload","            let captchaToken: String?","        }","        let payload = Payload(","            type: report.type,","            title: report.title,","            description: report.description,","            contactEmail: report.contactEmail,","            extraFields: report.extraFields,","            deviceInfo: DeviceInfoPayload(","                appName: deviceInfo.appName,","                appVersion: deviceInfo.appVersion,","                buildNumber: deviceInfo.buildNumber,","                model: deviceInfo.model,","                osName: deviceInfo.osName,","                osVersion: deviceInfo.osVersion","            ),","            captchaToken: captchaToken","        )","","        var request = URLRequest(url: endpoint)","        request.httpMethod = \"POST\"","        request.setValue(\"application\/json\", forHTTPHeaderField: \"Content-Type\")","        request.httpBody = try JSONEncoder().encode(payload)","","        let (data, response) = try await session.data(for: request)","        guard let http = response as? HTTPURLResponse, (200..<300).contains(http.statusCode) else {","            throw FeedbackSubmissionError.invalidResponse","        }","","        struct Response: Decodable { let issueNumber: Int }","        return try JSONDecoder().decode(Response.self, from: data).issueNumber","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Your relay can then call GitHub itself using "},{"type":"reference","identifier":"doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/IssueBodyFormatter","isActive":true},{"type":"text","text":" for the body, or store the report in a database, or fan it out to multiple destinations — the client is unchanged."}]},{"anchor":"A-test-transport","level":2,"type":"heading","text":"A test transport"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For unit tests, build a transport that records calls and returns a canned result:"}]},{"code":["final class RecordingTransport: FeedbackTransport, @unchecked Sendable {","    private(set) var submitted: [(FeedbackReport, DeviceInfo)] = []","    var nextResult: Result<Int, any Error> = .success(0)","","    func submit(_ report: FeedbackReport, deviceInfo: DeviceInfo) async throws -> Int {","        submitted.append((report, deviceInfo))","        return try nextResult.get()","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Pass it to "},{"identifier":"doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/FeedbackClient\/init(transport:deviceInfo:)","type":"reference","isActive":true},{"type":"text","text":" with a fixed "},{"isActive":true,"type":"reference","identifier":"doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/DeviceInfo"},{"type":"text","text":" for fully deterministic tests."}]},{"level":2,"anchor":"Error-contract","type":"heading","text":"Error contract"},{"inlineContent":[{"type":"text","text":"Transports should throw "},{"isActive":true,"type":"reference","identifier":"doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/FeedbackSubmissionError"},{"type":"text","text":" for known conditions and let other errors propagate. The SDK’s UI layer "},{"code":"AppFeedbackUI\/FeedbackSheet","type":"codeVoice"},{"type":"text","text":" displays "},{"type":"codeVoice","code":"error.localizedDescription"},{"type":"text","text":" in an alert, so make sure your errors conform to "},{"type":"codeVoice","code":"LocalizedError"},{"text":" if you want friendly messages.","type":"text"}],"type":"paragraph"}]}],"kind":"article","topicSections":[{"identifiers":["doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/FeedbackTransport","doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/GitHubDirectTransport","doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/RelayTransport","doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/FeedbackSubmissionError"],"anchor":"Topics"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/appfeedbackcore\/customtransports"]}],"sections":[],"schemaVersion":{"major":0,"patch":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore"],["doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore","doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/SecretsAndTokens"]]},"metadata":{"role":"collectionGroup","modules":[{"name":"AppFeedbackCore"}],"title":"Custom Transports","roleHeading":"API Collection"},"references":{"doc://AppFeedbackCore/documentation/AppFeedbackCore/SecretsAndTokens":{"kind":"article","title":"Secrets and Tokens","role":"collectionGroup","abstract":[{"text":"Shipping a GitHub Personal Access Token inside an app binary is a known trade-off. Here’s how the SDK handles it honestly.","type":"text"}],"identifier":"doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/SecretsAndTokens","type":"topic","url":"\/documentation\/appfeedbackcore\/secretsandtokens"},"doc://AppFeedbackCore/documentation/AppFeedbackCore/FeedbackReport":{"url":"\/documentation\/appfeedbackcore\/feedbackreport","navigatorTitle":[{"text":"FeedbackReport","kind":"identifier"}],"abstract":[{"type":"text","text":"A single user-supplied feedback submission."}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"FeedbackReport","kind":"identifier"}],"title":"FeedbackReport","role":"symbol","identifier":"doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/FeedbackReport","type":"topic","kind":"symbol"},"doc://AppFeedbackCore/documentation/AppFeedbackCore/GitHubDirectTransport":{"identifier":"doc:\/