{"sections":[],"abstract":[{"text":"Replace ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/GitHubDirectTransport"},{"text":" with a relay server, a mock, or any other backend by conforming to ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/FeedbackTransport"},{"text":".","type":"text"}],"topicSections":[{"anchor":"Topics","identifiers":["doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/FeedbackTransport","doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/GitHubDirectTransport","doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/FeedbackSubmissionError"]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"content":[{"anchor":"Overview","text":"Overview","level":2,"type":"heading"},{"inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/FeedbackClient"},{"type":"text","text":" knows nothing about GitHub. All it does is collect "},{"type":"reference","isActive":true,"identifier":"doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/DeviceInfo"},{"type":"text","text":" and hand the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/FeedbackReport"},{"type":"text","text":" to its "},{"type":"reference","isActive":true,"identifier":"doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/FeedbackTransport"},{"type":"text","text":". Anything that can produce an "},{"type":"codeVoice","code":"Int"},{"text":" from that pair is a valid transport.","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["public protocol FeedbackTransport: Sendable {","    func submit(_ report: FeedbackReport, deviceInfo: DeviceInfo) async throws -> Int","}"]},{"type":"heading","text":"A relay transport","anchor":"A-relay-transport","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The most common reason to replace the default transport is to avoid shipping a GitHub PAT inside the app binary (see "},{"identifier":"doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/SecretsAndTokens","type":"reference","isActive":true},{"text":"). A small relay server holds the credential, exposes a thin HTTPS endpoint, and applies abuse controls. The client then looks like this:","type":"text"}]},{"type":"codeListing","code":["public struct RelayTransport: FeedbackTransport {","    public let endpoint: URL","    public let session: URLSession","","    public init(endpoint: URL, session: URLSession = .shared) {","        self.endpoint = endpoint","        self.session = session","    }","","    public func submit(_ report: FeedbackReport, deviceInfo: DeviceInfo) async throws -> Int {","        struct Payload: Encodable {","            let type: String","            let title: String","            let description: String","            let email: String?","            let appName: String","            let appVersion: String","            let buildNumber: String","            let model: String","            let osName: String","            let osVersion: String","        }","        let payload = Payload(","            type: report.type.rawValue,","            title: report.title,","            description: report.description,","            email: report.contactEmail,","            appName: deviceInfo.appName,","            appVersion: deviceInfo.appVersion,","            buildNumber: deviceInfo.buildNumber,","            model: deviceInfo.model,","            osName: deviceInfo.osName,","            osVersion: deviceInfo.osVersion","        )","","        var request = URLRequest(url: endpoint)","        request.httpMethod = \"POST\"","        request.setValue(\"application\/json\", forHTTPHeaderField: \"Content-Type\")","        request.httpBody = try JSONEncoder().encode(payload)","","        let (data, response) = try await session.data(for: request)","        guard let http = response as? HTTPURLResponse, (200..<300).contains(http.statusCode) else {","            throw FeedbackSubmissionError.invalidResponse","        }","","        struct Response: Decodable { let issueNumber: Int }","        return try JSONDecoder().decode(Response.self, from: data).issueNumber","    }","}"],"syntax":"swift"},{"inlineContent":[{"text":"Your relay can then call GitHub itself using ","type":"text"},{"identifier":"doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/IssueBodyFormatter","isActive":true,"type":"reference"},{"text":" for the body, or store the report in a database, or fan it out to multiple destinations — the client is unchanged.","type":"text"}],"type":"paragraph"},{"level":2,"text":"A test transport","type":"heading","anchor":"A-test-transport"},{"type":"paragraph","inlineContent":[{"text":"For unit tests, build a transport that records calls and returns a canned result:","type":"text"}]},{"code":["final class RecordingTransport: FeedbackTransport, @unchecked Sendable {","    private(set) var submitted: [(FeedbackReport, DeviceInfo)] = []","    var nextResult: Result<Int, any Error> = .success(0)","","    func submit(_ report: FeedbackReport, deviceInfo: DeviceInfo) async throws -> Int {","        submitted.append((report, deviceInfo))","        return try nextResult.get()","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"Pass it to ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/FeedbackClient\/init(transport:deviceInfo:)"},{"text":" with a fixed ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/DeviceInfo"},{"text":" for fully deterministic tests.","type":"text"}]},{"type":"heading","anchor":"Error-contract","level":2,"text":"Error contract"},{"type":"paragraph","inlineContent":[{"text":"Transports should throw ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/FeedbackSubmissionError"},{"text":" for known conditions and let other errors propagate. The SDK’s UI layer ","type":"text"},{"code":"AppFeedbackUI\/FeedbackSheet","type":"codeVoice"},{"text":" displays ","type":"text"},{"code":"error.localizedDescription","type":"codeVoice"},{"text":" in an alert, so make sure your errors conform to ","type":"text"},{"code":"LocalizedError","type":"codeVoice"},{"text":" if you want friendly messages.","type":"text"}]}],"kind":"content"}],"metadata":{"title":"Custom Transports","roleHeading":"API Collection","role":"collectionGroup","modules":[{"name":"AppFeedbackCore"}]},"hierarchy":{"paths":[["doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore"],["doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore","doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/SecretsAndTokens"]]},"seeAlsoSections":[{"title":"Transports","identifiers":["doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/SecretsAndTokens","doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/FeedbackTransport","doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/GitHubDirectTransport"],"anchor":"Transports","generated":true}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/appfeedbackcore\/customtransports"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/CustomTransports"},"kind":"article","references":{"doc://AppFeedbackCore/documentation/AppFeedbackCore/FeedbackSubmissionError":{"abstract":[{"type":"text","text":"Errors thrown by "},{"isActive":true,"type":"reference","identifier":"doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/GitHubDirectTransport"},{"type":"text","text":"."}],"identifier":"doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/FeedbackSubmissionError","kind":"symbol","url":"\/documentation\/appfeedbackcore\/feedbacksubmissionerror","fragments":[{"text":"enum","kind":"keyword"},{"kind":"text","text":" "},{"text":"FeedbackSubmissionError","kind":"identifier"}],"title":"FeedbackSubmissionError","type":"topic","navigatorTitle":[{"kind":"identifier","text":"FeedbackSubmissionError"}],"role":"symbol"},"doc://AppFeedbackCore/documentation/AppFeedbackCore/SecretsAndTokens":{"role":"collectionGroup","url":"\/documentation\/appfeedbackcore\/secretsandtokens","title":"Secrets and Tokens","type":"topic","kind":"article","identifier":"doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/SecretsAndTokens","abstract":[{"type":"text","text":"Shipping a GitHub Personal Access Token inside an app binary is a known trade-off. Here’s how the SDK handles it honestly."}]},"doc://AppFeedbackCore/documentation/AppFeedbackCore":{"title":"AppFeedbackCore","role":"collection","kind":"symbol","identifier":"doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore","url":"\/documentation\/appfeedbackcore","abstract":[{"text":"Submit feedback from any Apple platform to a GitHub repository in the exact body format the AppFeedback inbox parses.","type":"text"}],"type":"topic"},"doc://AppFeedbackCore/documentation/AppFeedbackCore/FeedbackReport":{"navigatorTitle":[{"kind":"identifier","text":"FeedbackReport"}],"url":"\/documentation\/appfeedbackcore\/feedbackreport","kind":"symbol","identifier":"doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/FeedbackReport","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"FeedbackReport"}],"role":"symbol","type":"topic","abstract":[{"text":"A single user-supplied feedback submission.","type":"text"}],"title":"FeedbackReport"},"doc://AppFeedbackCore/documentation/AppFeedbackCore/GitHubDirectTransport":{"kind":"symbol","abstract":[{"text":"A ","type":"text"},{"isActive":true,"identifier":"doc:\/\/AppFeedbackCore\/documentation\/AppFeedb