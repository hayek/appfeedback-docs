{"abstract":[{"text":"A fixed, structured shape for the GitHub issue body that the AppFeedback inbox can parse back into typed fields.","type":"text"}],"sections":[],"topicSections":[{"anchor":"Topics","identifiers":["doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/IssueBodyFormatter","doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/IssueBodyParser","doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/ParsedFeedbackBody"]}],"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","level":2,"anchor":"Overview","type":"heading"},{"inlineContent":[{"type":"text","text":"When "},{"isActive":true,"type":"reference","identifier":"doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/FeedbackClient\/submit(_:)"},{"type":"text","text":" runs, it asks the active "},{"isActive":true,"type":"reference","identifier":"doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/FeedbackTransport"},{"type":"text","text":" to deliver a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/FeedbackReport"},{"type":"text","text":". For "},{"isActive":true,"type":"reference","identifier":"doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/GitHubDirectTransport"},{"type":"text","text":", that means a "},{"type":"codeVoice","code":"POST \/repos\/{owner}\/{repo}\/issues"},{"type":"text","text":" with a JSON payload whose "},{"type":"codeVoice","code":"body"},{"type":"text","text":" is rendered by "},{"isActive":true,"type":"reference","identifier":"doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/IssueBodyFormatter"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The body is a "},{"type":"emphasis","inlineContent":[{"text":"wire contract","type":"text"}]},{"type":"text","text":" — it is the only way structured fields travel between the submitting app and the AppFeedback inbox. Any drift between the two halves silently loses columns in the inbox."}],"type":"paragraph"},{"text":"The exact shape","level":2,"anchor":"The-exact-shape","type":"heading"},{"inlineContent":[{"type":"text","text":"For a report with description, contact email, and an "},{"type":"codeVoice","code":"extraFields"},{"type":"text","text":" entry of "},{"type":"codeVoice","code":"\"Branch\": \"release\/1.4\""},{"type":"text","text":":"}],"type":"paragraph"},{"code":["<description>","","---","**Device Information:**","App: AcmeApp","App Version: 1.2.3 (456)","Device: MacBookPro18,1","macOS Version: Version 14.5 (Build 23F79)","","**Branch:**","release\/1.4","","**Contact Email:**","user@example.com","","---","👍 Votes: 0"],"syntax":"text","type":"codeListing"},{"inlineContent":[{"text":"If ","type":"text"},{"code":"contactEmail","type":"codeVoice"},{"text":" is ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" or empty, the entire ","type":"text"},{"code":"**Contact Email:**","type":"codeVoice"},{"text":" block is omitted. ","type":"text"},{"code":"extraFields","type":"codeVoice"},{"text":" are emitted in alphabetical key order, each rendered as ","type":"text"},{"code":"**Key:**\\nValue","type":"codeVoice"},{"text":". The trailing ","type":"text"},{"code":"👍 Votes: 0","type":"codeVoice"},{"text":" line is preserved for compatibility with vote-counting tooling.","type":"text"}],"type":"paragraph"},{"text":"OS labels per platform","level":2,"anchor":"OS-labels-per-platform","type":"heading"},{"inlineContent":[{"text":"The line above the email block uses the platform-specific label ","type":"text"},{"code":"osName Version:","type":"codeVoice"},{"text":". The parser regex ","type":"text"},{"code":"^(OS|macOS|iOS|iPadOS|watchOS|tvOS|visionOS) Version:","type":"codeVoice"},{"text":" recognises all of these:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"code":"macOS Version: …","type":"codeVoice"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"iOS Version: …","type":"codeVoice"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"iPadOS Version: …","type":"codeVoice"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"watchOS Version: …","type":"codeVoice"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"tvOS Version: …","type":"codeVoice"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"visionOS Version: …","type":"codeVoice"}]}]}],"type":"unorderedList"},{"inlineContent":[{"text":"So whichever value you put in ","type":"text"},{"isActive":true,"identifier":"doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/DeviceInfo\/osName","type":"reference"},{"text":", the inbox parses it correctly.","type":"text"}],"type":"paragraph"},{"text":"Labels","level":2,"anchor":"Labels","type":"heading"},{"inlineContent":[{"isActive":true,"identifier":"doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/IssueBodyFormatter\/labels(for:)","type":"reference"},{"text":" returns the two label strings that get applied to the GitHub issue:","type":"text"}],"type":"paragraph"},{"code":["IssueBodyFormatter.labels(for: .bug)","\/\/ [\"bug\", \"user-submitted\"]","","IssueBodyFormatter.labels(for: .featureRequest)","\/\/ [\"feature-request\", \"user-submitted\"]"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"These are also part of the contract: the inbox filters and groups by them.","type":"text"}],"type":"paragraph"},{"text":"Parsing it back","level":2,"anchor":"Parsing-it-back","type":"heading"},{"inlineContent":[{"isActive":true,"identifier":"doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/IssueBodyParser\/parse(_:)","type":"reference"},{"text":" is the inverse:","type":"text"}],"type":"paragraph"},{"code":["let body = IssueBodyFormatter.format(report: report, deviceInfo: info)","let parsed = IssueBodyParser.parse(body)","","parsed.appName       \/\/ \"AcmeApp\"","parsed.appVersion    \/\/ \"1.2.3 (456)\"","parsed.device        \/\/ \"MacBookPro18,1\"","parsed.osVersion     \/\/ \"Version 14.5 (Build 23F79)\"","parsed.email         \/\/ \"user@example.com\"","parsed.description   \/\/ \"<description>\""],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"The roundtrip is verified by the SDK’s test suite, so any change to the format gets caught at build time.","type":"text"}],"type":"paragraph"},{"text":"Resilience","level":2,"anchor":"Resilience","type":"heading"},{"inlineContent":[{"text":"The parser accepts a few variations seen in hand-written bodies:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Bold markers in any position ("},{"code":"**Contact Email:** foo@bar.com","type":"codeVoice"},{"type":"text","text":" on one line, or "},{"code":"**Contact Email:**\\nfoo@bar.com","type":"codeVoice"},{"type":"text","text":" on two)."}]}]},{"content":[{"inlineContent":[{"code":"OS Version:","type":"codeVoice"},{"type":"text","text":" as a generic label (treated like "},{"code":"macOS Version:","type":"codeVoice"},{"type":"text","text":")."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"code":"Horizontal rule (---)","type":"codeVoice"},{"text":" separators are stripped from the description.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Lines outside the ","type":"text"},{"code":"**Device Information:**","type":"codeVoice"},{"text":" block are treated as description content.","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"It does "},{"type":"emphasis","inlineContent":[{"text":"not","type":"text"}]},{"type":"text","text":" parse arbitrary YAML, JSON, or HTML — keep submissions plain text and the contract holds."}],"type":"paragraph"}]}],"identifier":{"url":"doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/BodyFormat","interfaceLanguage":"swift"},"schemaVersion":{"major":0,"patch":0,"minor":3},"variants":[{"traits":[{"interfaceLanguage":"swi