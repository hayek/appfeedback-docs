{"metadata":{"modules":[{"name":"AppFeedbackCore"}],"title":"The Body Format","role":"collectionGroup","roleHeading":"API Collection"},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/BodyFormat"},"seeAlsoSections":[{"identifiers":["doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/IssueBodyFormatter","doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/IssueBodyParser","doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/ParsedFeedbackBody"],"title":"The wire contract","generated":true,"anchor":"The-wire-contract"}],"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","anchor":"Overview","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"When "},{"type":"reference","isActive":true,"identifier":"doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/FeedbackClient\/submit(_:)"},{"type":"text","text":" runs, it asks the active "},{"type":"reference","isActive":true,"identifier":"doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/FeedbackTransport"},{"type":"text","text":" to deliver a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/FeedbackReport"},{"type":"text","text":". For "},{"type":"reference","isActive":true,"identifier":"doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/GitHubDirectTransport"},{"type":"text","text":", that means a "},{"type":"codeVoice","code":"POST \/repos\/{owner}\/{repo}\/issues"},{"type":"text","text":" with a JSON payload whose "},{"type":"codeVoice","code":"body"},{"type":"text","text":" is rendered by "},{"type":"reference","isActive":true,"identifier":"doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/IssueBodyFormatter"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"text":"The body is a ","type":"text"},{"inlineContent":[{"text":"wire contract","type":"text"}],"type":"emphasis"},{"text":" — it is the only way structured fields travel between the submitting app and the AppFeedback inbox. Any drift between the two halves silently loses columns in the inbox.","type":"text"}],"type":"paragraph"},{"text":"The exact shape","anchor":"The-exact-shape","level":2,"type":"heading"},{"inlineContent":[{"text":"For a report with description, contact email, and an ","type":"text"},{"type":"codeVoice","code":"extraFields"},{"type":"text","text":" entry of "},{"code":"\"Branch\": \"release\/1.4\"","type":"codeVoice"},{"type":"text","text":":"}],"type":"paragraph"},{"type":"codeListing","code":["<description>","","---","**Device Information:**","App: AcmeApp","App Version: 1.2.3 (456)","Device: MacBookPro18,1","macOS Version: Version 14.5 (Build 23F79)","","**Branch:**","release\/1.4","","**Contact Email:**","user@example.com","","---","👍 Votes: 0"],"syntax":"text"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"code":"contactEmail","type":"codeVoice"},{"type":"text","text":" is "},{"code":"nil","type":"codeVoice"},{"type":"text","text":" or empty, the entire "},{"code":"**Contact Email:**","type":"codeVoice"},{"type":"text","text":" block is omitted. "},{"code":"extraFields","type":"codeVoice"},{"type":"text","text":" are emitted in alphabetical key order, each rendered as "},{"code":"**Key:**\\nValue","type":"codeVoice"},{"type":"text","text":". The trailing "},{"code":"👍 Votes: 0","type":"codeVoice"},{"type":"text","text":" line is preserved for compatibility with vote-counting tooling."}]},{"anchor":"OS-labels-per-platform","type":"heading","text":"OS labels per platform","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The line above the email block uses the platform-specific label "},{"type":"codeVoice","code":"osName Version:"},{"type":"text","text":". The parser regex "},{"type":"codeVoice","code":"^(OS|macOS|iOS|iPadOS|watchOS|tvOS|visionOS|Android|Windows|Linux|Web|ChromeOS) Version:"},{"type":"text","text":" recognises all of these:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"code":"macOS Version: …","type":"codeVoice"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"iOS Version: …"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"iPadOS Version: …"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"watchOS Version: …"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"tvOS Version: …","type":"codeVoice"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"visionOS Version: …"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"code":"Android Version: …","type":"codeVoice"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"Windows Version: …"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"Linux Version: …","type":"codeVoice"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"Web Version: …"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"ChromeOS Version: …"}]}]}]},{"inlineContent":[{"type":"text","text":"So whichever value you put in "},{"identifier":"doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/DeviceInfo\/osName","isActive":true,"type":"reference"},{"text":", the inbox parses it correctly.","type":"text"}],"type":"paragraph"},{"level":2,"anchor":"Labels","type":"heading","text":"Labels"},{"inlineContent":[{"identifier":"doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/IssueBodyFormatter\/labels(for:)","type":"reference","isActive":true},{"text":" returns the two label strings that get applied to the GitHub issue:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["IssueBodyFormatter.labels(for: .bug)","\/\/ [\"bug\", \"user-submitted\"]","","IssueBodyFormatter.labels(for: .featureRequest)","\/\/ [\"feature-request\", \"user-submitted\"]"]},{"inlineContent":[{"type":"text","text":"These are also part of the contract: the inbox filters and groups by them."}],"type":"paragraph"},{"anchor":"Parsing-it-back","text":"Parsing it back","type":"heading","level":2},{"inlineContent":[{"identifier":"doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/IssueBodyParser\/parse(_:)","isActive":true,"type":"reference"},{"text":" is the inverse:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let body = IssueBodyFormatter.format(report: report, deviceInfo: info)","let parsed = IssueBodyParser.parse(body)","","parsed.appName       \/\/ \"AcmeApp\"","parsed.appVersion    \/\/ \"1.2.3 (456)\"","parsed.device        \/\/ \"MacBookPro18,1\"","parsed.osVersion     \/\/ \"Version 14.5 (Build 23F79)\"","parsed.email         \/\/ \"user@example.com\"","parsed.description   \/\/ \"<description>\""]},{"inlineContent":[{"type":"text","text":"The roundtrip is verified by the SDK’s test suite, so any change to the format gets caught at build time."}],"type":"paragraph"},{"anchor":"Resilience","text":"Resilience","type":"heading","level":2},{"inlineContent":[{"text":"The parser accepts a few variations seen in hand-written bodies:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Bold markers in any position (","type":"text"},{"type":"codeVoice","code":"**Contact Email:** foo@bar.com"},{"text":" on one line, or ","type":"text"},{"type":"codeVoice","code":"**Contact Email:**\\nfoo@bar.com"},{"text":" on two).","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"OS Version:"},{"type":"text","text":" as a generic label (treated like "},{"type":"codeVoice","code":"macOS Version:"},{"type":"text","text":")."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"Horizontal rule (---)","type":"codeVoice"},{"text":" separators are stripped from the description.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Lines outside the "},{"type":"codeVoice","code":"**Device Information:**"},{"type":"text","text":" block are treated as description content."}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"It does "},{"inlineContent":[{"type":"text","text":"not"}],"type":"emphasis"},{"text":" parse arbitrary YAML, JSON, or HTML — keep submissions plain text and the contract holds.","type":"text"}]}]}],"variants":[{"paths":["\/documentation\/appfeedbackcore\/bodyformat"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore"]]},"kind":"article","sections":[],"abstract":[{"type":"text","text":"A fixed, structured shape for the GitHub issue body that the AppFeedback inbox can parse back into typed fields."}],"schemaVersion":{"major":0,"minor":3,"patch":0},"topicSections":[{"anchor":"Topics","identifiers":["doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/IssueBodyFormatter","doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/IssueBodyParser","doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/ParsedFeedbackBody"]}],"references":{"doc://AppFeedbackCore/documentation/AppFeedbackCore/IssueBodyParser":{"title":"IssueBodyParser","abstract":[{"text":"The inverse of ","type":"text"},{"isActive":true,"identifier":"doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/IssueBodyFormatter","type":"reference"},{"text":": pulls structured fields out of a","type":"text"},{"text":" ","type":"text"},{"text":"GitHub issue body produced by the AppFeedback SDK (or a hand-written body","type":"text"},{"type":"text","text":" "},{"type":"text","text":"following the same shape)."}],"identifier":"doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/IssueBodyParser","kind":"symbol","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"IssueBodyParser","kind":"identifier"}],"type":"topic","role":"symbol","na