{"sections":[],"abstract":[{"type":"text","text":"Shipping a GitHub Personal Access Token inside an app binary is a known trade-off. Here’s how the SDK handles it honestly."}],"topicSections":[{"identifiers":["doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/GitHubDirectTransport","doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/CustomTransports"],"anchor":"Topics"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"primaryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"text":"Overview","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/GitHubDirectTransport","type":"reference"},{"text":" requires a ","type":"text"},{"type":"codeVoice","code":"token"},{"text":" parameter to POST to GitHub Issues. Wherever that token lives — embedded constant, obfuscated blob, fetched at runtime — the threat model is the same: ","type":"text"},{"inlineContent":[{"text":"anyone with the binary can recover the token","type":"text"}],"type":"strong"},{"text":". Disassembly, runtime memory dump, or a hooked HTTPS proxy will eventually surface it.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The SDK does not pretend otherwise. It exposes ","type":"text"},{"type":"codeVoice","code":"token: String"},{"text":" directly and lets you decide the trade-off:","type":"text"}]},{"rows":[[[{"inlineContent":[{"text":"Approach","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Effort","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Resists casual extraction","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Resists determined extraction","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Plaintext constant","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"trivial","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"no","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"no","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"XOR \/ obfuscated blob decoded at runtime","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"small","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"yes","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"no","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Token fetched from your server at app start","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"medium","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"yes","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"no (once fetched, lives in memory)","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Server-side relay holds the token","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"medium-high","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"yes","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"inlineContent":[{"type":"text","text":"yes"}],"type":"strong"}],"type":"paragraph"}]]],"type":"table","header":"row"},{"type":"paragraph","inlineContent":[{"text":"Only the last row genuinely contains the blast radius. The first three raise the bar; an attacker who actually wants the token will still get it.","type":"text"}]},{"type":"heading","level":2,"text":"Acceptable use of an embedded token","anchor":"Acceptable-use-of-an-embedded-token"},{"type":"paragraph","inlineContent":[{"text":"A PAT inside the binary is reasonable when:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"The repo is a "},{"inlineContent":[{"type":"text","text":"write-only"}],"type":"emphasis"},{"type":"text","text":" feedback inbox and the worst-case abuse is spam issues you can delete."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"You can rotate the PAT quickly if abuse occurs (and have monitoring to notice)."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"The PAT’s scope is the minimum that lets it open issues — typically "},{"type":"codeVoice","code":"public_repo"},{"type":"text","text":" or "},{"type":"codeVoice","code":"repo"},{"type":"text","text":" for a private repo, nothing more."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"You’re comfortable with someone using the same endpoint to spam your inbox."}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"text":"If any of these stop being true, move to a relay.","type":"text"}]},{"type":"heading","level":2,"text":"Moving to a relay","anchor":"Moving-to-a-relay"},{"type":"paragraph","inlineContent":[{"text":"The cleanest mitigation is to keep the credential on a server you control and expose a thin HTTPS endpoint. The SDK is designed for this — implement ","type":"text"},{"isActive":true,"identifier":"doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/FeedbackTransport","type":"reference"},{"text":" and your app never sees a GitHub token. See ","type":"text"},{"isActive":true,"identifier":"doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/CustomTransports","type":"reference"},{"text":" for a worked example.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Once the relay holds the token, you also get:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Rate-limiting per device \/ IP without burning GitHub’s API quota."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Spam filters before they reach your repo."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Optional attachments (screenshots, logs) via your own CDN — the GitHub REST API doesn’t accept binary uploads, but your server can mirror to one."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Schema evolution without shipping a new app version."}],"type":"paragraph"}]}]},{"type":"heading","level":2,"text":"Don’t store tokens in your repo","anchor":"Dont-store-tokens-in-your-repo"},{"type":"paragraph","inlineContent":[{"text":"Even if you’re embedding a PAT in the binary, the source should never have it in plaintext. Common pattern:","type":"text"}]},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Keep the obfuscated\/encoded form in source."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Decode it at runtime just before constructing the transport."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Restrict the PAT scope to issues-write only."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Have a documented rotation procedure."}],"type":"paragraph"}]}]}]}],"hierarchy":{"paths":[["doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore"]]},"metadata":{"roleHeading":"API Collection","title":"Secrets and Tokens","role":"collectionGroup","modules":[{"name":"AppFeedbackCore"}]},"seeAlsoSections":[{"title":"Transports","identifiers":["doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/CustomTransports","doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/FeedbackTransport","doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/GitHubDirectTransport"],"anchor":"Transports","generated":true}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/appfeedbackcore\/secretsandtokens"]}],"identifier":{"url":"doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/SecretsAndTokens","interfaceLanguage":"swift"},"kind":"article","references":{"doc://AppFeedbackCore/documentation/AppFeedbackCore":{"title":"AppFeedbackCore","role":"collection","kind":"symbol","identifier":"doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore","url":"\/documentation\/appfeedbackcore","abstract":[{"text":"Submit feedback from any Apple platform to a GitHub repository in the exact body format the AppFeedback inbox parses.","type":"text"}],"type":"topic"},"doc://AppFeedbackCore/documentation/AppFeedbackCore/GitHubDirectTransport":{"kind":"symbol","abstract":[{"text":"A ","type":"text"},{"isActive":true,"identifier":"doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/FeedbackTransport","type":"reference"},{"text":" that posts reports directly to the GitHub Issues","type":"text"},{"text":" ","type":"text"},{"text":"REST API.","type":"text"}],"navigatorTitle":[{"text":"GitHubDirectTransport","kind":"identifier"}],"role":"symbol","title":"GitHubDirectTransport","type":"topic","url":"\/documentation\/appfeedbackcore\/githubdirecttransport","identifier":"doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/GitHubDirectTransport","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"GitHubDirectTransport","kind":"identifier"}]},"doc://AppFeedbackCore/documentation/AppFeedbackCore/FeedbackReport":{"navigatorTitle":[{"kind":"identifier","text":"FeedbackReport"}],"url":"\/documentation\/appfeedbackcore\/feedbackreport","kind":"symbol","identifier":"doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/FeedbackReport","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"FeedbackReport"}],"role":"symbol","type":"topic","abstract":[{"text":"A single user-supplied feedback submission.","type":"text"}],"title":"FeedbackReport"},"doc://AppFeedbackCore/documentation/AppFeedbackCore/CustomTransports":{"url":"\/documentation\/appfeedbackcore\/customtransports","kind":"article","identifier":"doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/CustomTransports","role":"collectionGroup","type":"topic","abstract":[{"text":"Replace ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/GitHubDirectTransport"},{"type":"text","text":" with a relay server, a mock, or any other backend by conforming to "},{"isActive":true,"type":"reference","identifier":"doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/FeedbackTransport"},{"type":"text","text":"."}],"title":"Custom Transports"},"doc://AppFeedbackCore/documentation/AppFeedbackCore/FeedbackTransport":{"kind":"symbol","abstract":[{"type":"text","text":"Where a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/FeedbackReport"},{"text":" gets delivered.","type":"text"}],"navigatorTitle":[{"text":"FeedbackTransport","kind":"identifier"}],"role":"symbol","title":"FeedbackTransport","type":"topic","url":"\/documentation\/appfeedbackcore\/feedbacktransport","identifier":"doc:\/\/AppFeedbackCore\/documentation\/AppFeedbackCore\/FeedbackTransport","fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"FeedbackTransport"}]}}}