{"identifier":{"url":"doc:\/\/AppFeedbackUI\/documentation\/AppFeedbackUI","interfaceLanguage":"swift"},"abstract":[{"text":"A drop-in SwiftUI feedback sheet on top of ","type":"text"},{"code":"AppFeedbackCore","type":"codeVoice"},{"text":".","type":"text"}],"schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[],"variants":[{"paths":["\/documentation\/appfeedbackui"],"traits":[{"interfaceLanguage":"swift"}]}],"topicSections":[{"identifiers":["doc:\/\/AppFeedbackUI\/documentation\/AppFeedbackUI\/FeedbackSheet"],"anchor":"Essentials","title":"Essentials"},{"identifiers":["doc:\/\/AppFeedbackUI\/documentation\/AppFeedbackUI\/Theming","doc:\/\/AppFeedbackUI\/documentation\/AppFeedbackUI\/Localization","doc:\/\/AppFeedbackUI\/documentation\/AppFeedbackUI\/FeedbackTheme"],"anchor":"Customization","title":"Customization"}],"hierarchy":{"paths":[[]]},"metadata":{"role":"collection","title":"AppFeedbackUI","externalID":"AppFeedbackUI","modules":[{"name":"AppFeedbackUI"}],"symbolKind":"module","roleHeading":"Framework"},"kind":"symbol","primaryContentSections":[{"content":[{"type":"heading","anchor":"Overview","level":2,"text":"Overview"},{"inlineContent":[{"code":"AppFeedbackUI","type":"codeVoice"},{"type":"text","text":" ships a single, themeable view — "},{"type":"reference","isActive":true,"identifier":"doc:\/\/AppFeedbackUI\/documentation\/AppFeedbackUI\/FeedbackSheet"},{"type":"text","text":" — that handles the entire feedback flow: type selection, validated form, async submission, success animation, and dismissal. It runs on iOS, iPadOS, macOS, tvOS, watchOS, and visionOS with platform-appropriate styling."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"If you don’t want the bundled sheet — for instance, because you have your own form aesthetic — use ","type":"text"},{"code":"AppFeedbackCore\/FeedbackClient","type":"codeVoice"},{"text":" directly and skip this module entirely.","type":"text"}]},{"text":"Minimal integration","anchor":"Minimal-integration","type":"heading","level":3},{"code":["import AppFeedbackCore","import AppFeedbackUI","","struct ContentView: View {","    let feedback: FeedbackClient","    @State private var showFeedback = false","","    var body: some View {","        Button(\"Send Feedback\") { showFeedback = true }","            .sheet(isPresented: $showFeedback) {","                FeedbackSheet(client: feedback)","            }","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"The default theme uses red for bug reports, blue\/purple for feature requests, and English copy. Both can be overridden per call — see ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/AppFeedbackUI\/documentation\/AppFeedbackUI\/Theming"},{"text":" and ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/AppFeedbackUI\/documentation\/AppFeedbackUI\/Localization"},{"text":".","type":"text"}]},{"text":"What you get out of the box","anchor":"What-you-get-out-of-the-box","type":"heading","level":3},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Type selector"}],"type":"strong"},{"text":" — radio-style cards for bug and feature request.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Validated fields"}],"type":"strong"},{"text":" — title (required), description (required, character count up to a configurable limit), email (optional, soft-validated).","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Privacy notice"}],"type":"strong"},{"text":" — explicit “device information will be automatically included” line so users aren’t surprised.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Async submission"}]},{"type":"text","text":" — disables the button, shows a spinner, fires "},{"code":"onSubmit","type":"codeVoice"},{"type":"text","text":" or "},{"type":"codeVoice","code":"onError"},{"text":" callbacks.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Success animation"}],"type":"strong"},{"text":" — animated checkmark + the GitHub issue number, then dismiss via “Done”.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Keyboard shortcuts","type":"text"}],"type":"strong"},{"type":"text","text":" — ⌘↩ submits on macOS \/ iPadOS, default action key dismisses on success."}]}]}],"type":"unorderedList"}],"kind":"content"}],"references":{"doc://AppFeedbackUI/documentation/AppFeedbackUI":{"identifier":"doc:\/\/AppFeedbackUI\/documentation\/AppFeedbackUI","url":"\/documentation\/appfeedbackui","type":"topic","role":"collection","kind":"symbol","title":"AppFeedbackUI","abstract":[{"type":"text","text":"A drop-in SwiftUI feedback sheet on top of "},{"type":"codeVoice","code":"AppFeedbackCore"},{"type":"text","text":"."}]},"doc://AppFeedbackUI/documentation/AppFeedbackUI/Localization":{"kind":"article","identifier":"doc:\/\/AppFeedbackUI\/documentation\/AppFeedbackUI\/Localization","type":"topic","title":"Localization","role":"collectionGroup","url":"\/documentation\/appfeedbackui\/localization","abstract":[{"type":"text","text":"Pass pre-localized strings into "},{"type":"reference","identifier":"doc:\/\/AppFeedbackUI\/documentation\/AppFeedbackUI\/FeedbackTheme\/Copy-swift.struct","isActive":true},{"type":"text","text":" so the SDK doesn’t have to ship a strings table."}]},"doc://AppFeedbackUI/documentation/AppFeedbackUI/FeedbackTheme/Copy-swift.struct":{"abstract":[{"text":"Every visible string on the sheet.","type":"text"}],"identifier":"doc:\/\/AppFeedbackUI\/documentation\/AppFeedbackUI\/FeedbackTheme\/Copy-swift.struct","type":"topic","role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind"