{"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","level":2,"type":"heading","text":"Overview"},{"type":"paragraph","inlineContent":[{"code":"AppFeedbackUI","type":"codeVoice"},{"text":" ships a single, themeable view — ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/AppFeedbackUI\/documentation\/AppFeedbackUI\/FeedbackSheet"},{"text":" — that handles the entire feedback flow: type selection, validated form, async submission, success animation, and dismissal. It runs on iOS, iPadOS, macOS, tvOS, watchOS, and visionOS with platform-appropriate styling.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If you don’t want the bundled sheet — for instance, because you have your own form aesthetic — use ","type":"text"},{"code":"AppFeedbackCore\/FeedbackClient","type":"codeVoice"},{"text":" directly and skip this module entirely.","type":"text"}]},{"anchor":"Minimal-integration","level":3,"type":"heading","text":"Minimal integration"},{"syntax":"swift","type":"codeListing","code":["import AppFeedbackCore","import AppFeedbackUI","","struct ContentView: View {","    let feedback: FeedbackClient","    @State private var showFeedback = false","","    var body: some View {","        Button(\"Send Feedback\") { showFeedback = true }","            .sheet(isPresented: $showFeedback) {","                FeedbackSheet(client: feedback)","            }","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"The default theme uses red for bug reports, blue\/purple for feature requests, and English copy. Both can be overridden per call — see ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/AppFeedbackUI\/documentation\/AppFeedbackUI\/Theming"},{"text":" and ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/AppFeedbackUI\/documentation\/AppFeedbackUI\/Localization"},{"text":".","type":"text"}]},{"anchor":"What-you-get-out-of-the-box","level":3,"type":"heading","text":"What you get out of the box"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"text":"Type selector","type":"text"}],"type":"strong"},{"text":" — radio-style cards for bug and feature request.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Validated fields","type":"text"}],"type":"strong"},{"text":" — title (required), description (required, character count up to a configurable limit), email (optional, soft-validated).","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Privacy notice","type":"text"}],"type":"strong"},{"text":" — explicit “device information will be automatically included” line so users aren’t surprised.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Async submission"}],"type":"strong"},{"text":" — disables the button, shows a spinner, fires ","type":"text"},{"type":"codeVoice","code":"onSubmit"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"onError"},{"text":" callbacks.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Success animation","type":"text"}],"type":"strong"},{"text":" — animated checkmark + the GitHub issue number, then dismiss via “Done”.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Keyboard shortcuts","type":"text"}],"type":"strong"},{"text":" — ⌘↩ submits on macOS \/ iPadOS, default action key dismisses on success.","type":"text"}],"type":"paragraph"}]}]}]}],"metadata":{"role":"collection","externalID":"AppFeedbackUI","modules":[{"name":"AppFeedbackUI"}],"symbolKind":"module","title":"AppFeedbackUI","roleHeading":"Framework"},"abstract":[{"type":"text","text":"A drop-in SwiftUI feedback sheet on top of "},{"type":"codeVoice","code":"AppFeedbackCore"},{"type":"text","text":"."}],"topicSections":[{"identifiers":["doc:\/\/AppFeedbackUI\/